# /opt/hik-sync-boswa/.env  — config for the Boswa Hik-Connect sync agent.
# Boswa shares the Contabo box with Dunlop but lives in its OWN folder
# (/opt/hik-sync-boswa). Copy to /opt/hik-sync-boswa/.env, fill in, chmod 600.
# Do NOT commit the real .env.

# Boswa ingest edge function (project ref flplvvybmzqapklcftbq)
LOVABLE_FUNCTION_URL=https://flplvvybmzqapklcftbq.supabase.co/functions/v1/ingest-attendance

# Pre-shared secret. MUST equal the HIK_SYNC_SECRET set on the edge function.
HIK_SYNC_SECRET=<paste the generated secret here and in the Supabase function secret>

# Botswana, no DST.
TZ_OFFSET=+02:00

# Single Boswa account is configured in accounts.json (name "boswa"), so the
# legacy HIK_API_KEY/HIK_API_SECRET fallback below is not needed.
